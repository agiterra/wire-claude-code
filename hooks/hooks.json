{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"export CLAUDE_CODE_SESSION_ID=$CLAUDE_CODE_SESSION_ID\" >> \"$CLAUDE_ENV_FILE\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/disconnect.ts\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
